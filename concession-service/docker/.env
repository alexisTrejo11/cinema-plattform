# Copy this file to ../.env for docker-compose usage.
# The app container forces DB_HOST=db and ignores DATABASE_URL to avoid localhost issues.

APP_NAME=Cinema Backend: Concession Service API
APP_VERSION=1.0.0
API_HOST=0.0.0.0
API_PORT=8000
API_VERSION=2.0
DEBUG_MODE=true

REGISTRY_ADMIN_URL=http://registry-admin:8000

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=cinema_concession
POSTGRES_PORT=5432
POSTGRES_ECHO=false
# Local dev; Docker Compose sets POSTGRES_HOST=db and DATABASE_URL="".
POSTGRES_HOST=localhost

REDIS_HOST=redis
REDIS_PORT=6379

# JWT: JWT_SECRET_KEY and JWT_ALGORITHM are required. JWT_AUDIENCE / JWT_ISSUER
# are optional (omit or leave empty to skip aud/iss verification). JWT_LEEWAY_SECONDS defaults to 0.
JWT_SECRET_KEY=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_AUDIENCE=
JWT_ISSUER=
JWT_LEEWAY_SECONDS=0

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/cinema_concession
TEST_DATABASE_URL=postgresql+asyncpg://postgres:fedoraadmin@localhost:5432/cinema_concession_test

REDIS_URL=redis://redis:6379/0