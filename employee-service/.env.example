# Application
API_VERSION=1.0
DEBUG_MODE=false
SERVICE_NAME=employee-service

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=employee_service
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/employee_service

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=change-me-to-a-long-random-secret-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_AUDIENCE=cinema-platform
JWT_ISSUER=cinema-platform

# gRPC
GRPC_HOST=0.0.0.0
GRPC_PORT=50054

# Rate Limiting
RATE_LIMIT_DEFAULT=60/minute
