# Keep this file at the service root because Docker reads it from the build context root.
# Python cache and virtual environments
__pycache__/
*.py[cod]
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.venv/
env/

# Local environment and secrets
.env
.env.*
!.env.example
!.env.docker.example

# Build and VCS artifacts
.git/
.gitignore
.DS_Store
*.log
logs/

# Tooling and tests not needed at runtime
tests/
pytest.ini
pending-tasks.txt
