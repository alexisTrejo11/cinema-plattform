# Application metadata
APP_NAME=Cinema Backend: Billboard Service API
APP_VERSION=1.0.0

# Database
# Prefer DATABASE_URL in production so credentials live in one env variable.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/cinema_billboard
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cinema_billboard
DB_ECHO=false

# JWT
# Set a strong random value in production.
JWT_SECRET_KEY=change-me-to-a-long-random-secret
JWT_ALGORITHMS=HS256
JWT_AUDIENCE=
JWT_ISSUER=
JWT_LEEWAY_SECONDS=0
