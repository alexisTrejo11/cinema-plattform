# application metadata
app.AME=Cinema Backend: Billboard Service API
app.ERSION=1.0.0

# Database
# Prefer DATABASE_URL in production so credentials live in one env variable.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/cinema_billboard
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=cinema_billboard
POSTGRES_ECHO=false

# JWT
# Set a strong random value in production.
JWT_SECRET_KEY=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_AUDIENCE=
JWT_ISSUER=
JWT_LEEWAY_SECONDS=0

# Catalog service gRPC target used by showtime validation and seat provisioning
GRPC_CATALOG_TARGET=localhost:50056
