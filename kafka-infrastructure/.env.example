# Copy to .env and adjust. Used by docker compose in this folder.

# Host port for Kafka (apps on your machine use bootstrap: localhost:<this>)
KAFKA_HOST_PORT=9092

# Bootstrap for processes on the host. Usually localhost:9092 — must match KAFKA_HOST_PORT.
# If you run Kafka UI or producers only inside Docker, they use kafka:29092 (see docker-compose).

# When other machines or VMs reach this host, set your LAN IP or hostname so advertised listeners match.
# Default localhost is correct for local-only development.
KAFKA_ADVERTISED_HOST=localhost

# Zookeeper client port on host (optional; default 2181)
ZOOKEEPER_PORT=2181

# Kafka UI (Provectus) — open http://localhost:<this> in a browser
KAFKA_UI_PORT=8090

# --- Connecting other services (same machine) ---
# 1) Start this stack first: docker compose up -d
# 2) In another compose file, attach to the shared network and use bootstrap kafka:29092:
#
#    networks:
#      cinema_kafka:
#        external: true
#        name: cinema_kafka
#
#    services:
#      your-app:
#        networks: [cinema_kafka]
#        environment:
#          KAFKA_BOOTSTRAP_SERVERS: kafka:29092
#
# Apps running on the host (not in Docker) should use: localhost:${KAFKA_HOST_PORT:-9092}
